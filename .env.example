# LLM-Provider — jede OpenAI-kompatible API.
# Beispiele:
#   Ollama (lokal):    http://localhost:11434/v1   Modell z.B. qwen3:14b
#   vLLM (lokal):      http://localhost:8000/v1    Modell = servierter Modellname
#   OpenRouter:        https://openrouter.ai/api/v1
#   Anthropic:         https://api.anthropic.com/v1/  Modell z.B. claude-sonnet-5
TALOS_BASE_URL=http://localhost:11434/v1
TALOS_API_KEY=none
TALOS_MODEL=qwen3:14b
# Optional: günstiges Modell für Reflexion/einfache Schritte
TALOS_SMALL_MODEL=

# Telegram (Token von @BotFather; eigene User-ID von @userinfobot)
TALOS_TELEGRAM_TOKEN=
TALOS_TELEGRAM_ALLOWED=

# Daten-Verzeichnis (Memory, Lessons)
TALOS_DATA_DIR=data
